# =============================================================================
# Trend Intelligence — Complete .env
# Copy this to .env and fill in your values.
# Sections marked [REQUIRED] will break the app if missing.
# Sections marked [OPTIONAL] enable specific features.
# =============================================================================

# ─── GitHub API [OPTIONAL] ───────────────────────────────────────────────────
# Optional token to increase GitHub Search API rate limits for developer adoption.
# Create a Personal Access Token (classic or fine-grained) at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── NewsAPI [REQUIRED for news source validation] ───────────────────────────
# Get a free key at https://newsapi.org (free for developers)
NEWSAPI_KEY=your_newsapi_key_here

# ─── Reddit API [DEPRECATED / OPTIONAL] ───────────────────────────────────────
# Reddit is deprecated in v4.0 but credentials are kept for backwards compatibility.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendIntelligence/1.0 by YourUsername

# ─── Groq API [REQUIRED for AI features] ─────────────────────────────────────
# Get a free key at https://console.groq.com
# Free tier: 14,400 requests/day on llama3-70b-8192
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database [REQUIRED] ──────────────────────────────────────────────────────
# Supabase: Settings > Database > Connection string (URI format)
# IMPORTANT: Use the "Transaction" pooler URL for Render free (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── Redis [REQUIRED] ─────────────────────────────────────────────────────────
# Upstash: https://console.upstash.com → Create Database → REST API
# Free tier: 10,000 commands/day, 256MB
REDIS_URL=https://your-db.upstash.io
REDIS_TOKEN=your_upstash_redis_token

# ─── URLs [REQUIRED for production] ──────────────────────────────────────────
# Set these to your local or deployed URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Environment: "development" or "production"
ENVIRONMENT=development

# ─── Auth (Tier 3.4) [REQUIRED for login/watchlists] ─────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=key

# ─── QStash / Internal Jobs (Tier 4.5) [OPTIONAL but STRONGLY recommended] ───
# Without this, jobs stop when Render free tier sleeps (every 15 min).
# Setup:
#   1. Go to https://console.upstash.com → QStash
#   2. Create two schedules:
#      POST https://your-app.onrender.com/api/internal/poll    every 60s
#      POST https://your-app.onrender.com/api/internal/forecast every 30min
#   3. Add custom header: X-Internal-Secret: <value below>
#   4. Set the same value here:
INTERNAL_SECRET=replace-with-any-strong-random-string

# ─── Email Alerts (Tier 2.2) [OPTIONAL] ──────────────────────────────────────
# Get a free API key at https://resend.com (3,000 emails/month free)
# Without this, alert matches are only logged — no email is sent
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# ─── Reddit Sources [DEPRECATED / OPTIONAL] ──────────────────────────────────
# Comma-separated subreddits to monitor (Legacy: kept for backwards compatibility)
REDDIT_SUBREDDITS=programming,technology,worldnews,MachineLearning,artificial,investing

# ─── Polling / Caching [OPTIONAL] ────────────────────────────────────────────
# How often to poll feeds (seconds). Ignored if using QStash.
POLLING_INTERVAL_SECONDS=60
# Cache TTL for current trends (seconds)
CACHE_TTL_SECONDS=3600

# ─── Next.js Frontend (.env.local in /frontend) ───────────────────────────────
# Create /frontend/.env.local with:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
#   NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/trends



